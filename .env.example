# WiFi-Media Environment Configuration
# Copy this to .env and customize

# ── Server ─────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# ── Security ────────────────────────────────────────────────
# IMPORTANT: Change this in production!
JWT_SECRET=wifi-media-super-secret-key-change-me-in-production
JWT_EXPIRES_IN=7d

# ── TVHeadend ───────────────────────────────────────────────
TVHEADEND_URL=http://tvheadend:9981
TVHEADEND_USER=admin
TVHEADEND_PASS=admin

# ── Media Library ───────────────────────────────────────────
MEDIA_PATH=./media

# ── Database ────────────────────────────────────────────────
DB_PATH=/data/wifi-media.db

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Network ─────────────────────────────────────────────────
# Your local WiFi hotspot IP (used for device discovery)
LOCAL_IP=192.168.1.1
TZ=Asia/Ho_Chi_Minh

# ── Branding ────────────────────────────────────────────────
APP_NAME=WiFi-Media
APP_TAGLINE=Entertainment. Anywhere. Offline.
